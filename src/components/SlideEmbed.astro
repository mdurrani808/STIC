---
interface Props {
  topic: string;
  title: string;
}

const { topic, title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const htmlSrc = `${base}/slides/${topic}/${topic}.html`;
const pdfSrc  = `${base}/slides/${topic}/${topic}.pdf`;
const orgSrc  = `${base}/slides/${topic}/${topic}.org`;
---

<div class="slide-wrapper">
  <div class="slide-frame">
    <iframe
      src={htmlSrc}
      title={title}
      allowfullscreen
    />
  </div>
  <div class="slide-links">
    <a href={htmlSrc} target="_blank" rel="noopener">Open fullscreen ↗</a>
    <a href={pdfSrc} download>Download PDF</a>
    <a href={orgSrc} download>Download .org source</a>
  </div>
</div>

<style>
  .slide-wrapper {
    margin: 1.5rem 0;
  }

  .slide-frame {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    border-radius: 6px;
    overflow: hidden;
  }

  .slide-frame iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .slide-links {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.6rem;
    font-size: 0.875rem;
  }
</style>
